# Base da API Laravel consumida pelo site.
# Sempre inclua o sufixo /api.
#
# Desenvolvimento local (Laravel rodando com `php artisan serve`):
#   NEXT_PUBLIC_API_BASE=http://localhost:8000/api
#
# Producao (API em subdominio):
#   NEXT_PUBLIC_API_BASE=https://api.seudominio.com.br/api
NEXT_PUBLIC_API_BASE=http://localhost:8000/api
